{
  "name": "transcribe-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "asr:dev": "uv run --project asr_server uvicorn --app-dir asr_server server:app --host 127.0.0.1 --port 8000",
    "asr:health": "curl -sS http://127.0.0.1:8000/health",
    "build": "tsc -p tsconfig.json",
    "deploy": "npm run deploy:commands",
    "deploy:commands": "tsx src/deploy-commands.ts",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "tsx --test test/**/*.test.ts",
    "test:summary:live": "LIVE_CODEX_SUMMARY_TEST=1 tsx --test test/summary.integration.test.ts"
  },
  "dependencies": {
    "@discordjs/voice": "^0.19.2",
    "discord.js": "^14.26.4",
    "dotenv": "^17.2.3",
    "opusscript": "0.0.8",
    "prism-media": "^1.3.5"
  },
  "overrides": {
    "undici": "6.27.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
